{
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react",
    "lib": ["es2017"],
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "dist",
    "strict": true,
    "target": "esnext",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "types/**/*.ts",
    "services/**/*.ts",
    "hooks/**/*.ts",
    "components/**/*.tsx",
    "index.ts"
  ],
  "exclude": [
    "node_modules",
    "example",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js"
  ]
}